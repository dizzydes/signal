# Database
DATABASE_URL=postgresql://user:pass@host:5432/signal

# GitHub (classic PAT with `repo` scope)
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=dizzydes
GITHUB_REPO=signal
GITHUB_BASE_BRANCH=main

# Railway (team API token — GraphQL + variable mutations)
RAILWAY_API_TOKEN=
RAILWAY_PROJECT_ID=
RAILWAY_PRODUCTION_ENVIRONMENT_ID=
RAILWAY_PATIENT_WEB_SERVICE_ID=

# Agent (Claude Code SDK)
ANTHROPIC_API_KEY=sk-ant-...
AGENT_MODEL=claude-sonnet-4-6
AGENT_TIMEOUT_MS=180000

# Healer loop
HEAL_INTERVAL_MS=3000
GIT_USER_NAME=autoheal
GIT_USER_EMAIL=autoheal@users.noreply.github.com

# Poller loop
POLL_INTERVAL_MS=5000

# Dashboard embed — URL of the deployed patient-web
PATIENT_WEB_URL=http://localhost:3001

# Patient services
# patient-web: 0..1 (fraction of /api/status calls that return 500)
FAILURE_RATE=0
# patient-worker: 1 to enable the memory-leak mode
MEMORY_LEAK=0

# PostHog (optional — poller stub only today)
POSTHOG_PROJECT_ID=
POSTHOG_API_KEY=
