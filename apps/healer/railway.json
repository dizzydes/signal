{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm install --frozen-lockfile=false && pnpm -F @signal/shared build && pnpm -F healer build",
    "watchPatterns": [
      "apps/healer/**",
      "packages/shared/**",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "package.json"
    ]
  },
  "deploy": {
    "startCommand": "pnpm -F healer start",
    "restartPolicyType": "ALWAYS"
  }
}
