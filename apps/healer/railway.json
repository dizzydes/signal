{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npm install && npx -y skills add railwayapp/railway-skills && npm run build",
    "watchPatterns": ["apps/healer/**"]
  },
  "deploy": {
    "startCommand": "npm start",
    "restartPolicyType": "ALWAYS"
  }
}
